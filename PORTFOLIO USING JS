  <script>
    /* Greeting */
    const greetings = ["नमस्कार", "Hello", "Hola", "Bonjour", "Ciao", "こんにちは", "안녕하세요"];
    let gi = 0;
    setInterval(() => {
      document.getElementById("greeting").innerText =
        greetings[gi++ % greetings.length];
    }, 1000);

    /* AUTO SECTION CHANGE (3s FIXED) */
    const order = [
      "home", "about", "skills", "projects",
      "education", "certifications", "activities", "research", "contact"
    ];
    let idx = 0, auto = true;
    ["wheel", "keydown", "touchstart"].forEach(e => {
      window.addEventListener(e, () => auto = false);
    });
    setTimeout(() => {
      setInterval(() => {
        if (auto && idx < order.length) {
          document.getElementById(order[idx++])
            .scrollIntoView({ behavior: "smooth" });
        }
      }, 5000);
    }, 1500);
  </script>

