    section {
      min-height: 100vh;
      padding: 110px 20px 80px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    h2 {
      font-size: 2.5rem;
      color: #4caf50;
      margin-bottom: 20px;
    }

    /* NAVBAR */
    nav {
      position: fixed;
      top: 0;
      width: 100%;
      background: rgba(0, 0, 0, 0.6);
      backdrop-filter: blur(8px);
      display: flex;
      justify-content: center;
      gap: 25px;
      padding: 15px;
      z-index: 1000;
    }

    nav a {
      color: white;
      text-decoration: none;
      transition: .3s;
    }

    nav a:hover {
      color: #4caf50;
    }

    /* DESIGNED BY */
    .top-left {
      position: fixed;
      top: 15px;
      left: 20px;
      font-weight: bold;
      z-index: 1001;
    }

    /* SECTION TYPING */
    .section-typing {
      font-size: 2.3rem;
      font-weight: 800;
      color: #eaffea;
      white-space: nowrap;
      overflow: hidden;
      border-right: 3px solid #ff4757;
      width: 0;
      margin-bottom: 25px;
      animation: typingLoop 4s steps(35, end) infinite,
        blink .7s infinite;
    }

    @keyframes typingLoop {
      0% {
        width: 0;
      }

      70% {
        width: 36ch;
      }

      100% {
        width: 0;
      }
    }

    @keyframes blink {
      50% {
        border-color: transparent;
      }
    }

    /* HERO */
    .changing-text {
      font-size: 3rem;
    }

    .name {
      font-size: 2.2rem;
      font-family: "Brush Script MT", cursive;
      color: #0dd0d7;
    }

    .typing {
      font-size: 3rem;
      font-weight: bold;
      border-right: 3px solid #ff4757;
      white-space: nowrap;
      overflow: hidden;
      width: 18ch;
      animation: typing 3s steps(30, end) forwards, blink .7s infinite;
    }

    @keyframes typing {
      from {
        width: 0;
      }

      to {
        width: 18ch;
      }
    }

    /* COMMON */
    .box {
      max-width: 950px;
      background: rgba(255, 255, 255, 0.05);
      padding: 30px;
      border-radius: 12px;
    }

    .skills {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: center;
    }

    .skills span {
      padding: 10px 18px;
      border: 1px solid #4caf50;
      border-radius: 20px;
    }

    footer {
      padding: 20px;
      background: #000;
      text-align: center;
    }
  </style>
